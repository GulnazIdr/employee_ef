<Page x:Class="EmployeeEF.Pages.PageEmployee"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:EmployeeEF.Pages"
      xmlns:Icon="http://metro.mahapps.com/winfx/xaml/iconpacks"
      xmlns:command="clr-namespace:EmployeeEF.Commands"
      xmlns:core ="clr-namespace:EmployeeEF.Models"
      mc:Ignorable="d" 
      xmlns:rule ="clr-namespace:EmployeeEF.Validation"
      Loaded="Page_Loaded"
      d:DesignHeight="300" d:DesignWidth="520"
      Title="PageEmployee">
  

    <Page.CommandBindings>
        <CommandBinding Command="{x:Static command:DataCommands.Edit}" Executed="EditCommandBinding_Executed" 
                  CanExecute="EditCommandBinding_CanExecute"/>

        <CommandBinding Command="{x:Static command:DataCommands.Delete}" Executed="DeleteCommandBinding_Executed" 
               CanExecute="DeleteCommandBinding_CanExecute"/>

        <CommandBinding Command="Save" Executed="SaveCommandBinding_Executed" 
                    CanExecute="SaveCommandBinding_CanExecute"/>

        <CommandBinding Command="Find" Executed="FindCommandBinding_Executed" 
                    CanExecute="FindCommandBinding_CanExecute"/>

        <CommandBinding Command="New" Executed="AddCommandBinding_Executed" 
                    CanExecute="AddCommandBinding_CanExecute"/>

        <CommandBinding Command="Undo" Executed="UndoCommandBinding_Executed" 
                        CanExecute="UndoCommandBinding_CanExecute"/>
    </Page.CommandBindings>
    
    <Page.Resources>
        <DataTemplate x:Key="DateTemplate">
            <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" 
               Text="{Binding Birthday, StringFormat={}{0:dd.MM.yyyy}}"/>
        </DataTemplate>

        <DataTemplate x:Key="EditingDateTemplate">
            <DatePicker SelectedDate="{Binding Birthday, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
        </DataTemplate>

        <core:TitleList x:Key="listTitle"/>
    </Page.Resources>

    <StackPanel Margin="3" Background="{StaticResource BackgroundWithResource}">
        <Menu>
            <MenuItem Header="Действие">
                <MenuItem Header="Отменить" Command="Undo"></MenuItem>
                <MenuItem Header="Создать" Command="New"></MenuItem>
                <MenuItem Header="Редактировать" Command="command:DataCommands.Edit"></MenuItem>
                <MenuItem Header="Сохранить" Command="Save"></MenuItem>
                <MenuItem Header="Найти" Command="Find"></MenuItem>
                <Separator></Separator>
                <MenuItem Header="Удалить" Command="command:DataCommands.Delete"></MenuItem>
            </MenuItem>
            <MenuItem Header="Отменить"  Command="Undo"></MenuItem>
        </Menu>

        <ToolBar Name="ToolBar1" Margin="3">
            <Button Name="Undo" Command="Undo" ToolTip="Отменить редактирование / создание" Margin="5,2,5,2">
                <Image Source="/Images/undo.png" Width="12" Height="12"/>
            </Button>

            <Button Name="Add"  Command="New" ToolTip="Добавить нового сотрудника" Margin="5,2,5,2">
                <Image Source="/Images/add.png" Width="12" Height="12"/>
            </Button>

            <Button Name="Edit" Command="command:DataCommands.Edit" ToolTip="Редактировать данные сотрудника" Margin="5,2,5,2">
                <Image Source="/Images/edit.png" Width="12" Height="12"/>
            </Button>

            <Button Name="View" ToolTip="Посмотреть данные сотрудника" Margin="5,2,5,2">
                <Image Source="/Images/find.png" Width="12" Height="12"/>
            </Button>

            <Button Name="Save" Command="Save" ToolTip="Сохранить данные сотрудника" Margin="5,2,5,2">
                <Image Source="/Images/save.png" Width="12" Height="12"/>
            </Button>

            <Button Name="Back" Command="Undo" ToolTip="Отменить" Margin="5,2,5,2">
                <Image Source="/Images/delete.png" Width="12" Height="12"/>
            </Button>
        </ToolBar>

        <DataGrid  x:Name="emplGrid" ItemsSource="{Binding}" AutoGenerateColumns="False" 
                   HorizontalAlignment="Left" MaxWidth="1000" MaxHeight="295" RowBackground="#FFE6D3EF"
                   AlternatingRowBackground="#FC96CFD4" BorderBrush="#FF1F33EB" BorderThickness="3"
                   RowHeight="25" Cursor="Hand" CanUserAddRows="False" CanUserDeleteRows="False" Width="800"  IsReadOnly="True">

            <DataGrid.RowValidationErrorTemplate>
                <ControlTemplate>
                    <Grid Margin="0,-2,0,-2" ToolTip="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type DataGridRow}},
                        Path=(Validation.Errors)[0].ErrorContent}">
                        <Ellipse StrokeThickness="0" Fill="Red" Width="{TemplateBinding FontSize}"
                                 Height="{TemplateBinding FontSize}"/>
                        <TextBlock Text="!" FontSize="{TemplateBinding FontSize}" FontWeight="Bold"
                                   Foreground="White" HorizontalAlignment="Center"/>
                    </Grid>
                </ControlTemplate>
            </DataGrid.RowValidationErrorTemplate>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Фамилия" Binding="{Binding Lastname, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <DataGridTextColumn  Header="Имя" Binding="{Binding Firstname, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="Отчество" Binding="{Binding Patronymic, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                
                <DataGridComboBoxColumn   Header="Должность" ItemsSource="{Binding Source={StaticResource listTitle}}"
                                          DisplayMemberPath="TitleName" SelectedValueBinding="{Binding Path=TitleId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          SelectedValuePath="TitleId"/>
                
                <DataGridTemplateColumn Header="Дата рождения"  CellTemplate="{StaticResource DateTemplate}"
                                     CellEditingTemplate="{StaticResource EditingDateTemplate}"/>
                
                <DataGridTextColumn  Header="Телефон" Binding="{Binding Telephone, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                <DataGridTextColumn Header="Электронная почта" EditingElementStyle="{StaticResource errorStyle}">
                    <DataGridTextColumn.Binding>
                        <Binding Path="Email" Mode="TwoWay" UpdateSourceTrigger="PropertyChanged" ValidatesOnExceptions="True">
                            <Binding.ValidationRules>
                                <rule:EmailRule />
                            </Binding.ValidationRules>
                        </Binding>
                    </DataGridTextColumn.Binding>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>
    </StackPanel>
</Page>
